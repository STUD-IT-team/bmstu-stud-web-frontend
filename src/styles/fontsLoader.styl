_font_default(font-family)
  font-family font-family
  font-style normal
  font-stretch normal

@font-face
  _font_default(ALS-Sector)
  src local(ALS-Sector-Bold),
  url(../res/fonts/ALS_Sector/ALS_Sector_Bold.ttf) format("truetype"),
  url(../res/fonts/ALS_Sector/ALS_Sector_Bold.woff) format("woff")
  font-weight 700
@font-face
  _font_default(ALS-Sector)
  src local(ALS-Sector-SemiBold),
  url(../res/fonts/ALS_Sector/ALS_Sector_Bold.ttf) format("truetype"),
  url(../res/fonts/ALS_Sector/ALS_Sector_Bold.woff) format("woff")
  font-weight 600
@font-face
  _font_default(ALS-Sector)
  src local(ALS-Sector-Regular),
  url(../res/fonts/ALS_Sector/ALS_Sector_Regular.ttf) format("truetype"),
  url(../res/fonts/ALS_Sector/ALS_Sector_Bold.woff) format("woff")
  font-weight 500


@font-face
  _font_default(Ekaterina-Velikaya-One)
  src local(Ekaterina-Velikaya-One-Regular),
  url(../res/fonts/EkaterinaVelikayaOne/EkaterinaVelikayaOne.ttf) format("truetype"),
  url(../res/fonts/EkaterinaVelikayaOne/EkaterinaVelikayaOne.woff) format("woff")
  font-weight 500

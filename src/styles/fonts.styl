font-large-extra()
    font-family ALS-Sector, Roboto, monospace
    line-height 1.2
    font-size calc(2vw + 1.5rem)
font-large()
    font-family ALS-Sector, Roboto, monospace
    line-height 1.2
    font-size calc(1vw + 1rem)
font-medium()
    font-family ALS-Sector, Roboto, monospace
    line-height 1.2
    font-size calc(.7vw + .7rem)
font-small()
    font-family ALS-Sector, Roboto, monospace
    line-height 1.2
    font-size calc(.5vw + .7rem)
font-small-extra()
    font-family ALS-Sector, Roboto, monospace
    line-height 1.2
    font-size calc(0.3vw + .7rem)

font-bold()
    font-weight 700
font-normal()
    font-weight 500
font-thin()
    font-weight 400
